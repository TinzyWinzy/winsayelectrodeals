# === Supabase Configuration ===
# Get these from Supabase Dashboard -> Project Settings -> API
NEXT_PUBLIC_SUPABASE_URL=https://lqoqfzrastvvdcfzncct.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# === Admin Authorization ===
# Comma-separated list of email addresses allowed to access /leads, /schedule, /settings
ADMIN_EMAILS=admin@winsay.co.zw

# === Supabase Service Role Key (for seed scripts only, never in browser) ===
SUPABASE_SERVICE_KEY=

# === PayNow Configuration ===
PAYNOW_INTEGRATION_ID=
PAYNOW_INTEGRATION_KEY=
PAYNOW_RESULT_URL=https://your-domain.com/api/payment/verify
PAYNOW_RETURN_URL=https://your-domain.com/confirmation

# === Upstash Redis (for rate limiting) ===
UPSTASH_REDIS_URL=
UPSTASH_REDIS_TOKEN=

# === Fallback ZIG Rate (used when RBZ API is unavailable) ===
NEXT_PUBLIC_FALLBACK_ZIG_RATE=26
